#4. Type DEGs
Idents(data)<-data$celltype
find_DEG<-function(cell_name="NEUT"){
  sub_cluster<-subset(data,idents = cell_name)
  Idents(sub_cluster)<-sub_cluster$type
  DEG_Mvsc <- FindMarkers(sub_cluster,
                          ident.1 = c('Sepsis'),
                          ident.2 = c('Control'),
                          verbose = FALSE ,
                          logfc.threshold = 0)
  DEG_Mvsc <- DEG_Mvsc %>%
    mutate(sig=case_when(avg_log2FC <= -0.25 & p_val_adj < 0.05 ~ 'down',
                         avg_log2FC >=  0.25 & p_val_adj < 0.05 ~ 'up',
                         p_val_adj > 0.05 ~ 'non',
                         avg_log2FC > -0.25 | avg_log2FC < 0.25 ~ 'non')) %>%
    mutate(gene=row.names(DEG_Mvsc)) %>%
	mutate(celltype=cell_name)
  return(DEG_Mvsc)
}
gene_list<-list()
for (cell in levels(data)) {
  print(cell)
  data1<-find_DEG(cell_name=cell)
  head(data1)
  gene_list[[cell]]<-data1
}
save(gene_list,file = "01_Type_DEG.rdata")
